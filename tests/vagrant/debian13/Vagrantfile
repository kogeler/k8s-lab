# -*- mode: ruby -*-
# vi: set ft=ruby :
#
# Local Debian 13 Trixie test VM for k8s-lab.
#
# Two NICs attached to two libvirt networks defined in ./libvirt-networks/:
#   * eth0 → mgmt-nat    (SSH + NAT egress; management plane)
#   * eth1 → ext6-mock   (mocked provider-facing IPv6 /64 segment,
#                         mimics the external plane from plan §4.1)
#
# The `probe-ext6` network is defined here but attached only to the optional
# probe VM; it shares the same L2 segment as ext6-mock so the probe can
# validate NodePort / MetalLB VIP reachability from an "external" viewpoint.
#
# vagrant-libvirt docs:
#   https://vagrant-libvirt.github.io/vagrant-libvirt/

Vagrant.configure("2") do |config|
  config.vm.box = ENV.fetch("K8SLAB_BOX", "debian/trixie64")
  config.vm.box_check_update = false
  config.ssh.forward_agent = true

  # Shared sync folders: keep the repo mounted so Ansible from inside the VM
  # (or a delegated Molecule scenario from outside) sees the same tree.
  config.vm.synced_folder "../../../", "/vagrant",
                          type: "rsync",
                          rsync__exclude: [".git/", ".artifacts/",
                                           ".vagrant/", ".terraform/",
                                           ".molecule/", "**/.molecule/"]

  # vCPU count — reused for libvirt.cpus and per-NIC virtio multiqueue.
  vcpus = Integer(ENV.fetch("K8SLAB_VCPUS", "8"))

  config.vm.provider :libvirt do |libvirt|
    libvirt.driver         = "kvm"
    libvirt.memory         = Integer(ENV.fetch("K8SLAB_MEM_MB", "6144"))
    libvirt.cpus           = vcpus
    libvirt.nested         = true
    libvirt.cpu_mode       = "host-passthrough"
    libvirt.machine_type   = "q35"
    libvirt.disk_bus       = "virtio"
    libvirt.nic_model_type = "virtio"
    libvirt.default_prefix = "k8slab_"

    # Virtio memballoon — host reclaims idle guest RAM when needed.
    libvirt.memballoon_enabled = true
    libvirt.memballoon_model   = "virtio"

    # Do NOT set `libvirt.graphics_type = "none"` — it drops the video
    # device and Debian 13 Trixie hangs in early boot (NICs never come
    # up, domifstat tx_bytes stays 0).

    # Virtio-RNG with /dev/urandom backing — avoids entropy starvation
    # during snap install, apt key verification, TLS handshakes.
    libvirt.random model: "random"

    # Host-side qemu-guest-agent channel. Debian 13 box ships the guest
    # side; this adds the virtio-serial unix socket so libvirt can drive
    # fsfreeze / graceful shutdown / in-guest IP reporting.
    libvirt.channel type: "unix",
                    target_name: "org.qemu.guest_agent.0",
                    target_type: "virtio"

    # Disk IO tuning. cache=unsafe ignores guest fsyncs — huge speedup
    # for apt/snap/mkfs (many small sync writes). Trade: host crash can
    # leave qcow2 inconsistent; throw-away VM, just re-run `make destroy
    # && make up`. io=threads compatible with any cache mode.
    # discard+detect_zeroes keep qcow2 sparse as guest TRIMs.
    libvirt.disk_driver cache: "unsafe",
                        io: "threads",
                        discard: "unmap",
                        detect_zeroes: "unmap"

    # Dedicated data disk backing the LXD Btrfs storage pool. The serial
    # is what pins the device path inside the guest:
    #   /dev/disk/by-id/virtio-k8slab-lxdpool
    # Using by-id keeps the contract independent of kernel probe order.
    # Formatting and mounting are done by the Molecule shared prepare step
    # (not by Vagrant), so the disk reaches the guest raw.
    libvirt.storage :file,
                    size: ENV.fetch("K8SLAB_LXD_POOL_GB", "40") + "G",
                    type: "qcow2",
                    bus: "virtio",
                    cache: "unsafe",
                    io: "threads",
                    discard: "unmap",
                    detect_zeroes: "unmap",
                    serial: "k8slab-lxdpool"
  end

  # --- host node ----------------------------------------------------------
  config.vm.define "host" do |host|
    host.vm.hostname = "k8slab-host"

    host.vm.network :private_network,
                    libvirt__network_name: "k8slab-mgmt-nat",
                    libvirt__dhcp_enabled: true,
                    libvirt__forward_mode: "nat",
                    libvirt__driver_queues: vcpus,
                    autostart: true

    # IPv6-only external segment. `type: "dhcp"` is the documented
    # vagrant-libvirt option that tells the plugin "do not compute any
    # IPAM — the guest will get its address from DHCP/RA on whatever
    # family the libvirt network serves". Without this flag the plugin's
    # IPv4-centric code path crashes on an IPv6-only network with
    # `undefined method 'to_range' for nil`.
    host.vm.network :private_network,
                    type: "dhcp",
                    libvirt__network_name: "k8slab-ext6-mock",
                    libvirt__dhcp_enabled: true,
                    libvirt__forward_mode: "none",
                    libvirt__guest_ipv6: true,
                    libvirt__driver_queues: vcpus,
                    autostart: true
  end

  # --- optional probe node -----------------------------------------------
  # Enabled with: K8SLAB_PROBE=1 vagrant up probe
  if ENV["K8SLAB_PROBE"] == "1"
    config.vm.define "probe", autostart: false do |probe|
      probe.vm.hostname = "k8slab-probe"
      probe.vm.provider :libvirt do |libvirt|
        libvirt.memory = 1024
        libvirt.cpus   = 1
      end

      probe.vm.network :private_network,
                       libvirt__network_name: "k8slab-mgmt-nat",
                       libvirt__dhcp_enabled: true,
                       libvirt__forward_mode: "nat",
                       autostart: true

      probe.vm.network :private_network,
                       type: "dhcp",
                       libvirt__network_name: "k8slab-probe-ext6",
                       libvirt__dhcp_enabled: true,
                       libvirt__forward_mode: "none",
                       libvirt__guest_ipv6: true,
                       autostart: true
    end
  end
end
