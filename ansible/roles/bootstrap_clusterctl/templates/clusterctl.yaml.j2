{{ ansible_managed | comment }}
# clusterctl config consumed via `clusterctl init --config <this file>`.
# Declares the CAPN infrastructure provider entry; core/kubeadm-bootstrap/
# kubeadm-control-plane providers come from clusterctl's built-in
# registry (kubernetes-sigs/cluster-api releases) and need no entry here.
#
# Provider list: https://main.cluster-api.sigs.k8s.io/clusterctl/configuration
---
providers:
  - name: "{{ _bootstrap_clusterctl_required_provider_name }}"
    url:  "{{ bootstrap_clusterctl_capn_provider_url }}"
    type: "InfrastructureProvider"
{% for entry in bootstrap_clusterctl_extra_providers %}
  - name: "{{ entry.name }}"
    url:  "{{ entry.url }}"
    type: "{{ entry.type }}"
{% endfor %}
{% if bootstrap_clusterctl_cert_manager_timeout | length > 0 %}

# cert-manager block — emitted only when the consumer overrides the
# wait timeout. clusterctl merges this partially with its bundled
# defaults (URL + version stay defaulted; only `timeout` overrides).
cert-manager:
  timeout: "{{ bootstrap_clusterctl_cert_manager_timeout }}"
{% endif %}
