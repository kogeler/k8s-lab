{# CAPN identity Secret (plan §16.4 + capn.linuxcontainers.org/reference/identity-secret.html). #}
{# Keys per spec: server, server-crt, client-crt, client-key, project. #}
{# `clusterctl.cluster.x-k8s.io/move=true` label appears only when      #}
{# k8s_lab_pivot_enabled=true so `clusterctl move` carries the Secret across.  #}
---
apiVersion: v1
kind: Secret
metadata:
  name: {{ bootstrap_capn_secret_name }}
  namespace: {{ _bootstrap_capn_secret_required_namespace }}
{% if bootstrap_capn_secret_pivot_enabled %}
  labels:
    clusterctl.cluster.x-k8s.io/move: "true"
{% endif %}
type: Opaque
stringData:
  server:     "https://{{ _bootstrap_capn_secret_https_target }}"
  project:    "{{ bootstrap_capn_secret_lxd_project }}"
  server-crt: |
{{ _bootstrap_capn_secret_server_cert_pem | indent(width=4, first=true) }}
  client-crt: |
{{ _bootstrap_capn_secret_client_cert_pem | indent(width=4, first=true) }}
  client-key: |
{{ _bootstrap_capn_secret_client_key_pem | indent(width=4, first=true) }}
