{{ ansible_managed | comment }}
# Environment file consumed by {{ bootstrap_k3s_service_name }}.service.
# k3s reads a handful of K3S_* variables (K3S_TOKEN, K3S_KUBECONFIG_MODE,
# …) so we keep this file around even when empty — the systemd unit
# references it with a leading `-` so missing content is tolerated.
#
# Populated fields only; anything not set here follows the flags on the
# ExecStart line in k3s.service.
{% if bootstrap_k3s_token | length > 0 %}
K3S_TOKEN={{ bootstrap_k3s_token }}
{% endif %}
