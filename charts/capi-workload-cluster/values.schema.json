{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "capi-workload-cluster values",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "cluster",
    "clusterClass",
    "kubernetes",
    "topology",
    "clusterNetwork",
    "loadBalancer",
    "apiProxy",
    "tests"
  ],
  "properties": {
    "cluster": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 63,
          "pattern": "^[a-z]([-a-z0-9]*[a-z0-9])?$"
        }
      }
    },
    "clusterClass": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 40,
          "pattern": "^[a-z]([-a-z0-9]*[a-z0-9])?$"
        },
        "namespace": {
          "type": "string",
          "maxLength": 63,
          "pattern": "^([a-z]([-a-z0-9]*[a-z0-9])?)?$"
        }
      }
    },
    "kubernetes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version"],
      "properties": {
        "version": {
          "type": "string",
          "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+(\\+[A-Za-z0-9.-]+)?$"
        }
      }
    },
    "topology": {
      "type": "object",
      "additionalProperties": false,
      "required": ["controlPlane", "workers"],
      "properties": {
        "controlPlane": {
          "type": "object",
          "additionalProperties": false,
          "required": ["replicas"],
          "properties": {
            "replicas": { "type": "integer", "minimum": 1, "maximum": 99 }
          }
        },
        "workers": {
          "type": "object",
          "additionalProperties": false,
          "required": ["replicas"],
          "properties": {
            "replicas": { "type": "integer", "minimum": 0, "maximum": 999 }
          }
        }
      }
    },
    "clusterNetwork": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pods", "services"],
      "properties": {
        "pods":     { "$ref": "#/$defs/cidrFamily" },
        "services": { "$ref": "#/$defs/cidrFamily" }
      }
    },
    "loadBalancer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lxc"],
      "properties": {
        "lxc": {
          "type": "object",
          "additionalProperties": false,
          "required": ["proxyApiPort"],
          "properties": {
            "proxyApiPort": {
              "type": "integer",
              "minimum": 0,
              "maximum": 65535,
              "description": "Override for the auto-derived API proxy port. 0 = use Adler-32 hash of cluster.name."
            }
          }
        }
      }
    },
    "apiProxy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["image", "infrastructureSecretName", "lbWaitTimeoutSeconds"],
      "properties": {
        "image": {
          "type": "string",
          "minLength": 1
        },
        "infrastructureSecretName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 253,
          "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?(\\.[a-z0-9]([-a-z0-9]*[a-z0-9])?)*$"
        },
        "lbWaitTimeoutSeconds": {
          "type": "integer",
          "minimum": 60,
          "maximum": 3600
        }
      }
    },
    "tests": {
      "type": "object",
      "additionalProperties": false,
      "required": ["image", "nodesUpTimeoutSeconds"],
      "properties": {
        "image": {
          "type": "string",
          "minLength": 1
        },
        "nodesUpTimeoutSeconds": {
          "type": "integer",
          "minimum": 60,
          "maximum": 7200
        }
      }
    }
  },
  "$defs": {
    "cidrFamily": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cidrBlocks"],
      "properties": {
        "cidrBlocks": {
          "type": "array",
          "minItems": 1,
          "maxItems": 2,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^([0-9.]+|[0-9a-fA-F:]+)/[0-9]+$"
          }
        }
      }
    }
  }
}
